# Contentus app configuration.
# Add the same values in Render Dashboard environment variables for deployment.

PORT=3000
CONTENTUS_MODE=production

# Supabase: Settings -> Data API for URL, Settings -> API Keys for publishable/anon key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Free-key or free-tier integrations.
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_DATA_API_KEY=
FIREBASE_API_KEY=
SESSION_SECRET=
