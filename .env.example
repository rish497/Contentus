# Contentus runs in demo/mock mode without any keys.
# Add these only when replacing mock routes with real integrations.

PORT=3000
CONTENTUS_MODE=demo

# Supabase: Settings -> Data API for URL, Settings -> API Keys for publishable/anon key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Free-key or free-tier integrations for future production mode.
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_DATA_API_KEY=
FIREBASE_API_KEY=
SESSION_SECRET=
