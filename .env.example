# Contentus app configuration.
# Add the same values in Render Dashboard environment variables for deployment.

PORT=3000
CONTENTUS_MODE=production

# Supabase: Settings -> Data API for URL, Settings -> API Keys for publishable/anon key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Featherless powers text/JSON AI routes.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
FEATHERLESS_VISION_MODEL=

# Gemini remains enabled for thumbnail image generation only.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
YOUTUBE_DATA_API_KEY=
FIREBASE_API_KEY=
SESSION_SECRET=

