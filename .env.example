# Contentus app configuration.
# Add the same values in Render Dashboard environment variables for deployment.

PORT=3000
CONTENTUS_MODE=production

# Supabase: Settings -> Data API for URL, Settings -> API Keys for publishable/anon key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Featherless powers text/JSON AI routes. Qwen2.5-72B is ungated and needs a
# Premium+ tier; Llama models are license-gated (require connecting HuggingFace)
# and return 403. For a Basic ($10, 15B cap) tier use e.g. Qwen/Qwen2.5-14B-Instruct.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
FEATHERLESS_VISION_MODEL=

# Thumbnail image generation. IMAGE_PROVIDER selects the preferred provider
# (pollinations = free + keyless, default; gemini = requires billing). The other
# provider is used as an automatic fallback if the preferred one fails.
IMAGE_PROVIDER=pollinations

# Pollinations is free and works with no key; set a token only to lift rate limits.
POLLINATIONS_MODEL=flux
POLLINATIONS_API_KEY=

# Gemini image generation (optional fallback; requires a billing-enabled key).
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ElevenLabs text-to-speech powers the Voiceover Studio. Get a key from
# elevenlabs.io -> Profile -> API Keys. ELEVENLABS_VOICE_ID is the default voice
# (any voice_id from your account); ELEVENLABS_MODEL defaults to eleven_multilingual_v2.
# ELEVENLABS_MAX_CHARS caps characters per clip to keep latency/cost in check.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MAX_CHARS=5000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
YOUTUBE_DATA_API_KEY=
FIREBASE_API_KEY=
SESSION_SECRET=

